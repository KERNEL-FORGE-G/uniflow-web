# UniFlow Application Environment Variables
# Copy this file to .env.local and fill in with your actual values

# Application
VITE_APP_NAME=UniFlow
VITE_APP_VERSION=1.0.0
VITE_API_BASE_URL=https://api.example.com
VITE_ENVIRONMENT=production

# Vercel
VERCEL_ENV=production
VERCEL_URL=https://uniflow.vercel.app

# Analytics (optional)
VITE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Feature Flags (optional)
VITE_FEATURE_BIOMETRIC=true
VITE_FEATURE_SMS_NOTIFICATIONS=true
VITE_FEATURE_VIDEO_CONFERENCING=true

# API Keys (if needed for external services)
VITE_EXTERNAL_API_KEY=
